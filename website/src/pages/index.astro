---
import Layout from '@layouts/Layout.astro'
import { Image, getImage } from 'astro:assets'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import DownloadButton from '../components/DownloadButton.astro'
import AEDemo from '../components/AEDemo.astro'
import FeatureSection from '../components/FeatureSection.astro'
import Screenshot from '../components/Screenshot.astro'
import ThemeCompareSlider from '../components/ThemeCompareSlider.astro'
import vscodeShot from '../assets/main-demo-image-vscode.png'
import aeLight from '../assets/main-demo-image-light.png'
import aeDark from '../assets/main-demo-image-dark.png'
import frontmatterShot from '../assets/frontmatter-sidebar-overview.png'
import coverFieldShot from '../assets/nested-image-field.png'
import mdxShot from '../assets/mdx-builder-1.png'
import imagePreviewShot from '../assets/image-preview-demo.png'
import copyeditShot from '../assets/copyedit-highlights.png'
import commandPaletteShot from '../assets/command-palette.png'
import draftsShot from '../assets/file-manager-drafts-filter.png'

const RELEASE_BASE =
  'https://github.com/dannysmith/astro-editor/releases/latest/download'
const debUrl = `${RELEASE_BASE}/astro-editor-latest.deb`
const rpmUrl = `${RELEASE_BASE}/astro-editor-latest.rpm`

// The Astro Editor shot spans the hero (~1040px, 2x ≈ 2080); VS Code is smaller.
const heroImageWidths = [640, 1024, 1536, 2048]

// Dark variant of the Astro Editor screenshot, served via a <picture> source
// when the visitor's OS is in dark mode (the page follows prefers-color-scheme).
const aeDarkOptimised = await getImage({
  src: aeDark,
  format: 'webp',
  widths: heroImageWidths,
})

// The focused-writing surface typed out by the hero demo.
const heroDemo = `# The case for boring tools

I used to keep my drafts in one app and the frontmatter in another. Every switch broke my train of thought.

Now I just *write*. The words stay in front of me and everything else gets out of the way.`

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Astro Editor',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: ['macOS', 'Windows', 'Linux'],
  description:
    'A focused, schema-aware markdown editor for Astro content collections.',
  url: 'https://astroeditor.danny.is/',
  author: {
    '@type': 'Person',
    name: 'Danny Smith',
    url: 'https://danny.is',
  },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  downloadUrl: 'https://astroeditor.danny.is/',
}
---

<Layout
  title="Astro Editor — A focused markdown editor for Astro content collections"
  description="Astro Editor is a native, distraction-free markdown editor that reads your Astro content collection schemas and turns frontmatter into clean, schema-aware forms. For writer mode, not coder mode."
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  {
    /*
    Homepage (built up phase by phase).
    Section order: Header → Hero → Download → Frontmatter → Designed for Writing
    → MDX Components → Working with Images → Other Features → Video → Footer.
  */
  }

  <SiteHeader />

  <main>
    <section id="hero" class="section section--hero">
      <div class="container hero">
        <p class="eyebrow">For Astro content collections</p>
        <h1>Writer mode for your Astro content.</h1>
        <p class="hero-sub">
          A native, distraction-free markdown editor that understands Astro
          content collections. It reads your Zod schemas, turns frontmatter into
          clean forms, and gets out of the way so you can write. Your files stay
          exactly where they are.
        </p>

        <div class="hero-cta">
          <DownloadButton platform="macos" />
          <DownloadButton platform="windows" />
          <a class="docs-link" href="/getting-started/">Read the docs →</a>
        </div>

        <div class="hero-visual">
          <picture class="shot shot--app">
            <source
              srcset={aeDarkOptimised.srcSet.attribute}
              sizes="(max-width: 1099px) 92vw, 1040px"
              media="(prefers-color-scheme: dark)"
              type="image/webp"
            />
            <Image
              src={aeLight}
              alt="The same file open in Astro Editor: a file list on the left, a schema-aware frontmatter form with a cover image on the right, and clean prose in the middle."
              loading="eager"
              widths={heroImageWidths}
              sizes="(max-width: 1099px) 92vw, 1040px"
            />
          </picture>

          <p class="contrast-text">
            The same file in VS Code looks like this — a less-than-ideal
            environment for writer mode.
          </p>

          <div class="shot shot--vscode">
            <Image
              src={vscodeShot}
              alt="The same content file open in VS Code — a wall of raw YAML frontmatter above the prose, surrounded by editor chrome."
              loading="lazy"
              widths={heroImageWidths}
              sizes="(max-width: 880px) 92vw, 820px"
            />
          </div>
        </div>

        <div class="focus-demo">
          <p class="focus-demo-lead">
            …and when you want to disappear into the writing — panels hidden,
            focus mode on, everything but the current line dimmed away.
          </p>
          <AEDemo code={heroDemo} />
        </div>
      </div>
    </section>

    <section id="download" class="section">
      <div class="container download-section">
        <h2>Download</h2>
        <p class="lede">
          Free and open source. Native builds for macOS, Windows, and Linux.
        </p>

        <div class="downloads">
          <div class="primary-row">
            <DownloadButton platform="macos" />
            <DownloadButton platform="windows" />
          </div>

          <div class="linux">
            <DownloadButton platform="linux" />
            <p class="linux-alt">
              Linux is in beta. Also available as a{' '}
              <a href={debUrl}>.deb</a> or <a href={rpmUrl}>.rpm</a> package.
            </p>
          </div>

          <p class="brew">
            Or install via Homebrew:
            <code>brew install --cask astro-editor</code>
          </p>
        </div>
      </div>
    </section>

    <FeatureSection
      id="frontmatter"
      eyebrow="Frontmatter"
      title="Forms built from your schema, not guesswork"
    >
      <p>
        Astro Editor reads your collection's Zod schema and renders the right
        control for every field — text inputs, date pickers, enum dropdowns, tag
        arrays, booleans, nested objects.
      </p>
      <p>
        Every field in the schema shows up, even the ones a file doesn't have
        yet. No more digging through <code>content.config.ts</code> to remember what's
        required, what's optional, or what an enum's allowed values were.
      </p>
      <Screenshot
        slot="media"
        src={frontmatterShot}
        alt="Astro Editor with the markdown editor on the left and a frontmatter panel on the right showing Title, Source URL, Slug, Draft, Description, Pub Date, Tags and Category fields generated from the schema."
        caption="Fields generated from the collection schema, right beside the editor."
      />
    </FeatureSection>

    <FeatureSection
      id="writing"
      eyebrow="Designed for writing"
      title="A writing surface, not a code editor"
      reverse
    >
      <p>
        Typography inspired by iA Writer, a focus mode that dims everything but
        the sentence you're on, and typewriter scrolling that keeps your cursor
        in a comfortable spot on screen.
      </p>
      <ul class="feature-list">
        <li>Focus mode &amp; typewriter scrolling</li>
        <li>Keyboard shortcuts for every formatting command</li>
        <li>Paste a URL over selected text to make a link</li>
        <li>⌥-hover any link or image path to preview it</li>
        <li>Beautiful in light and dark — drag the handle to compare</li>
      </ul>
      <ThemeCompareSlider
        slot="media"
        lightSrc={aeLight}
        darkSrc={aeDark}
        alt="The same Astro Editor window shown in light and dark themes."
      />
    </FeatureSection>

    <FeatureSection
      id="mdx"
      eyebrow="MDX components"
      title="Insert components without leaving the keyboard"
    >
      <p>
        In an MDX file, open the component inserter, search your project's
        components, and drop one in. Astro Editor reads each component's props
        and walks you through filling them — tab from field to field.
      </p>
      <p>
        Astro, React, Vue, and Svelte components all show up side by side, each
        tagged with its framework.
      </p>
      <Screenshot
        slot="media"
        src={mdxShot}
        alt="Astro Editor's component inserter open over an MDX file, listing components including InfoBox (Vue), Callout (Astro), Card (Vue), BookmarkCard (Astro) and Alert (React)."
        caption="Search and insert components from across your project's frameworks."
      />
    </FeatureSection>

    <FeatureSection
      id="images"
      eyebrow="Images"
      title="Drop in an image, get a clean link"
      reverse
    >
      <p>
        Drag an image into the editor and Astro Editor copies it into the right
        assets folder, gives it a web-safe name, and inserts a relative link —
        no manual file wrangling.
      </p>
      <p>
        The same smart image handling powers schema image fields in the
        frontmatter panel, and ⌥-hovering any image path pops up an instant
        preview.
      </p>
      <div slot="media" class="media-stack">
        <Screenshot
          src={imagePreviewShot}
          alt="An image path in the editor being hovered, with a thumbnail preview floating in the bottom-right corner of the window."
          caption="⌥-hover an image path or URL to preview it in the corner."
        />
        <Screenshot
          src={coverFieldShot}
          alt="A schema-driven Cover Image field showing an image path, a Change Image button, a thumbnail preview and an Alt text input."
          caption="The same handling in a schema image field — drag-and-drop with a live thumbnail."
        />
      </div>
    </FeatureSection>

    <section id="features" class="section">
      <div class="container">
        <h2 class="section-heading">And the day-to-day stuff, too</h2>
        <div class="cards">
          <article class="card">
            <Screenshot
              src={draftsShot}
              alt="The file list sidebar filtered to drafts, with two files marked by red Draft badges, alongside filter and sort controls."
            />
            <h3>Drafts, filtering &amp; sorting</h3>
            <p>
              Spot drafts at a glance, filter them in or out, and sort
              collections by name or date.
            </p>
          </article>
          <article class="card">
            <Screenshot
              src={copyeditShot}
              alt="Prose in the editor with words colour-coded by part of speech — nouns, verbs, adjectives, adverbs and conjunctions in different colours."
            />
            <h3>Copyedit modes</h3>
            <p>
              Colour-code parts of speech to catch overused adverbs and tighten
              your prose.
            </p>
          </article>
          <article class="card">
            <Screenshot
              src={commandPaletteShot}
              alt="Astro Editor's command palette open over a document, listing File and Navigation commands like New File, Close File and Toggle Sidebar."
            />
            <h3>Command palette</h3>
            <p>
              The whole app is keyboard-navigable. Open the palette to jump
              anywhere or run any command.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section id="video" class="section">
      <div class="container">
        <h2>See it in action</h2>
        <p class="placeholder">YouTube facade — Phase 5</p>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  /* Layout primitives (.container, .section, --home-* tokens) and the Flexoki
     palette live in Layout.astro's global styles. */
  .section--hero {
    border-top: none;
  }

  /* ---- Hero ---- */
  .hero {
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero h1 {
    margin-top: 1rem;
    margin-inline: auto;
    max-width: 16ch;
  }

  .hero-sub {
    margin: 1.25rem auto 0;
    max-width: 42rem;
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .hero-cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .docs-link {
    color: var(--color-text);
    font-weight: 500;
    padding: 0.5rem 0.25rem;

    &:hover {
      color: var(--color-accent);
      text-decoration: none;
    }
  }

  .hero-visual {
    margin-top: 3.5rem;
  }

  /* Screenshots are captured on macOS and already carry their own window
     shadow, so they're rendered bare — no frame, border, or background. */
  .shot {
    display: block;
    margin-inline: auto;

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
    }
  }

  .shot--app {
    max-width: 1040px;
  }

  .shot--vscode {
    max-width: 820px;
  }

  .contrast-text {
    margin: 2.75rem auto;
    max-width: 34rem;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    line-height: 1.4;
    font-weight: 500;
    color: var(--color-text);
  }

  .focus-demo {
    margin-top: 4rem;
    max-width: 42rem;
    margin-inline: auto;
    text-align: left;
  }

  .focus-demo-lead {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  /* ---- Feature sections ---- */
  .feature-list {
    margin-top: 1.25rem;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .feature-list li {
    position: relative;
    padding-left: 1.4rem;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .media-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ---- "And more" cards ---- */
  .section-heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .card h3 {
    margin-top: 1.25rem;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .card p {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .cards {
      grid-template-columns: 1fr;
      max-width: 28rem;
      margin-inline: auto;
    }
  }

  .download-section {
    text-align: center;
  }

  .lede {
    margin-top: 0.75rem;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
  }

  .downloads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .primary-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .linux {
    width: 100%;
    max-width: 36rem;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .linux-alt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    a {
      color: var(--color-text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;

      &:hover {
        color: var(--color-text);
      }
    }
  }

  .brew {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    code {
      margin-left: 0.35rem;
      padding: 0.15rem 0.4rem;
      border-radius: 0.3rem;
      background: var(--color-bg-2);
      border: 1px solid var(--color-border);
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--color-text);
    }
  }

  @media (max-width: 600px) {
    .primary-row {
      width: 100%;
    }
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Temporary scaffold marker — removed as each section is built out. */
  .placeholder {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
