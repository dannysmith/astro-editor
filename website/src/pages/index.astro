---
import Layout from '@layouts/Layout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import DownloadButton from '../components/DownloadButton.astro'

const RELEASE_BASE =
  'https://github.com/dannysmith/astro-editor/releases/latest/download'
const debUrl = `${RELEASE_BASE}/astro-editor-latest.deb`
const rpmUrl = `${RELEASE_BASE}/astro-editor-latest.rpm`

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Astro Editor',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: ['macOS', 'Windows', 'Linux'],
  description:
    'A focused, schema-aware markdown editor for Astro content collections.',
  url: 'https://astroeditor.danny.is/',
  author: {
    '@type': 'Person',
    name: 'Danny Smith',
    url: 'https://danny.is',
  },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  downloadUrl: 'https://astroeditor.danny.is/',
}
---

<Layout
  title="Astro Editor — A focused markdown editor for Astro content collections"
  description="Astro Editor is a native, distraction-free markdown editor that reads your Astro content collection schemas and turns frontmatter into clean, schema-aware forms. For writer mode, not coder mode."
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  {
    /*
    Homepage (built up phase by phase).
    Section order: Header → Hero → Download → Frontmatter → Designed for Writing
    → MDX Components → Working with Images → Other Features → Video → Footer.
  */
  }

  <SiteHeader />

  <main>
    <section id="hero" class="section section--hero">
      <div class="container">
        <h1>Hero</h1>
        <p class="placeholder">
          VS Code ↔ Astro Editor contrast + focused-writing demo — Phase 3
        </p>
      </div>
    </section>

    <section id="download" class="section">
      <div class="container download-section">
        <h2>Download</h2>
        <p class="lede">
          Free and open source. Native builds for macOS, Windows, and Linux.
        </p>

        <div class="downloads">
          <div class="primary-row">
            <DownloadButton platform="macos" />
            <DownloadButton platform="windows" />
          </div>

          <div class="linux">
            <DownloadButton platform="linux" />
            <p class="linux-alt">
              Linux is in beta. Also available as a{' '}
              <a href={debUrl}>.deb</a> or <a href={rpmUrl}>.rpm</a> package.
            </p>
          </div>

          <p class="brew">
            Or install via Homebrew:
            <code>brew install --cask astro-editor</code>
          </p>
        </div>
      </div>
    </section>

    <section id="frontmatter" class="section">
      <div class="container">
        <h2>Working with frontmatter</h2>
        <p class="placeholder">Schema-aware forms — Phase 4</p>
      </div>
    </section>

    <section id="writing" class="section">
      <div class="container">
        <h2>Designed for writing</h2>
        <p class="placeholder">
          Light/dark slider, focus &amp; typewriter — Phase 4
        </p>
      </div>
    </section>

    <section id="mdx" class="section">
      <div class="container">
        <h2>Inserting MDX components</h2>
        <p class="placeholder">MDX inserter sequence — Phase 4</p>
      </div>
    </section>

    <section id="images" class="section">
      <div class="container">
        <h2>Working with images</h2>
        <p class="placeholder">Drag, rename, link, hover preview — Phase 4</p>
      </div>
    </section>

    <section id="features" class="section">
      <div class="container">
        <h2>And more</h2>
        <p class="placeholder">
          Drafts, copyedit modes, command palette — Phase 4
        </p>
      </div>
    </section>

    <section id="video" class="section">
      <div class="container">
        <h2>See it in action</h2>
        <p class="placeholder">YouTube facade — Phase 5</p>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  /* Shared layout tokens for the homepage. Palette comes from Layout.astro's
     Flexoki variables (which already swap on prefers-color-scheme). */
  :root {
    --home-container: 1100px;
    --home-pad-x: 1.5rem;
    --home-section-y: 6rem;
  }

  .container {
    width: 100%;
    max-width: var(--home-container);
    margin-inline: auto;
    padding-inline: var(--home-pad-x);
  }

  .section {
    padding-block: var(--home-section-y);
    border-top: 1px solid var(--color-border);
  }

  .section--hero {
    border-top: none;
  }

  .download-section {
    text-align: center;
  }

  .lede {
    margin-top: 0.75rem;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
  }

  .downloads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .primary-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .linux {
    width: 100%;
    max-width: 36rem;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .linux-alt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    a {
      color: var(--color-text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;

      &:hover {
        color: var(--color-text);
      }
    }
  }

  .brew {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    code {
      margin-left: 0.35rem;
      padding: 0.15rem 0.4rem;
      border-radius: 0.3rem;
      background: var(--color-bg-2);
      border: 1px solid var(--color-border);
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--color-text);
    }
  }

  @media (max-width: 600px) {
    .primary-row {
      width: 100%;
    }
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Temporary scaffold marker — removed as each section is built out. */
  .placeholder {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Tablet */
  @media (max-width: 900px) {
    :root {
      --home-section-y: 4rem;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    :root {
      --home-pad-x: 1.25rem;
      --home-section-y: 3rem;
    }
  }
</style>
