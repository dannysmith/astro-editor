---
import Layout from '@layouts/Layout.astro'
import { Image, getImage } from 'astro:assets'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import DownloadButton from '../components/DownloadButton.astro'
import AEDemo from '../components/AEDemo.astro'
import vscodeShot from '../assets/main-demo-image-vscode.png'
import aeLight from '../assets/main-demo-image-light.png'
import aeDark from '../assets/main-demo-image-dark.png'

const RELEASE_BASE =
  'https://github.com/dannysmith/astro-editor/releases/latest/download'
const debUrl = `${RELEASE_BASE}/astro-editor-latest.deb`
const rpmUrl = `${RELEASE_BASE}/astro-editor-latest.rpm`

// The Astro Editor shot spans the hero (~1040px, 2x ≈ 2080); VS Code is smaller.
const heroImageWidths = [640, 1024, 1536, 2048]

// Dark variant of the Astro Editor screenshot, served via a <picture> source
// when the visitor's OS is in dark mode (the page follows prefers-color-scheme).
const aeDarkOptimised = await getImage({
  src: aeDark,
  format: 'webp',
  widths: heroImageWidths,
})

// The focused-writing surface typed out by the hero demo.
const heroDemo = `# The case for boring tools

I used to keep my drafts in one app and the frontmatter in another. Every switch broke my train of thought.

Now I just *write*. The words stay in front of me and everything else gets out of the way.`

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Astro Editor',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: ['macOS', 'Windows', 'Linux'],
  description:
    'A focused, schema-aware markdown editor for Astro content collections.',
  url: 'https://astroeditor.danny.is/',
  author: {
    '@type': 'Person',
    name: 'Danny Smith',
    url: 'https://danny.is',
  },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  downloadUrl: 'https://astroeditor.danny.is/',
}
---

<Layout
  title="Astro Editor — A focused markdown editor for Astro content collections"
  description="Astro Editor is a native, distraction-free markdown editor that reads your Astro content collection schemas and turns frontmatter into clean, schema-aware forms. For writer mode, not coder mode."
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  {
    /*
    Homepage (built up phase by phase).
    Section order: Header → Hero → Download → Frontmatter → Designed for Writing
    → MDX Components → Working with Images → Other Features → Video → Footer.
  */
  }

  <SiteHeader />

  <main>
    <section id="hero" class="section section--hero">
      <div class="container hero">
        <p class="eyebrow">For Astro content collections</p>
        <h1>Writer mode for your Astro content.</h1>
        <p class="hero-sub">
          A native, distraction-free markdown editor that understands Astro
          content collections. It reads your Zod schemas, turns frontmatter into
          clean forms, and gets out of the way so you can write. Your files stay
          exactly where they are.
        </p>

        <div class="hero-cta">
          <DownloadButton platform="macos" />
          <DownloadButton platform="windows" />
          <a class="docs-link" href="/getting-started/">Read the docs →</a>
        </div>

        <div class="hero-visual">
          <picture class="shot shot--app">
            <source
              srcset={aeDarkOptimised.srcSet.attribute}
              sizes="(max-width: 1099px) 92vw, 1040px"
              media="(prefers-color-scheme: dark)"
              type="image/webp"
            />
            <Image
              src={aeLight}
              alt="The same file open in Astro Editor: a file list on the left, a schema-aware frontmatter form with a cover image on the right, and clean prose in the middle."
              loading="eager"
              widths={heroImageWidths}
              sizes="(max-width: 1099px) 92vw, 1040px"
            />
          </picture>

          <p class="contrast-text">
            The same file in VS Code looks like this — a less-than-ideal
            environment for writer mode.
          </p>

          <div class="shot shot--vscode">
            <Image
              src={vscodeShot}
              alt="The same content file open in VS Code — a wall of raw YAML frontmatter above the prose, surrounded by editor chrome."
              loading="lazy"
              widths={heroImageWidths}
              sizes="(max-width: 880px) 92vw, 820px"
            />
          </div>
        </div>

        <div class="focus-demo">
          <p class="focus-demo-lead">
            …and when you want to disappear into the writing — panels hidden,
            focus mode on, everything but the current line dimmed away.
          </p>
          <AEDemo code={heroDemo} />
        </div>
      </div>
    </section>

    <section id="download" class="section">
      <div class="container download-section">
        <h2>Download</h2>
        <p class="lede">
          Free and open source. Native builds for macOS, Windows, and Linux.
        </p>

        <div class="downloads">
          <div class="primary-row">
            <DownloadButton platform="macos" />
            <DownloadButton platform="windows" />
          </div>

          <div class="linux">
            <DownloadButton platform="linux" />
            <p class="linux-alt">
              Linux is in beta. Also available as a{' '}
              <a href={debUrl}>.deb</a> or <a href={rpmUrl}>.rpm</a> package.
            </p>
          </div>

          <p class="brew">
            Or install via Homebrew:
            <code>brew install --cask astro-editor</code>
          </p>
        </div>
      </div>
    </section>

    <section id="frontmatter" class="section">
      <div class="container">
        <h2>Working with frontmatter</h2>
        <p class="placeholder">Schema-aware forms — Phase 4</p>
      </div>
    </section>

    <section id="writing" class="section">
      <div class="container">
        <h2>Designed for writing</h2>
        <p class="placeholder">
          Light/dark slider, focus &amp; typewriter — Phase 4
        </p>
      </div>
    </section>

    <section id="mdx" class="section">
      <div class="container">
        <h2>Inserting MDX components</h2>
        <p class="placeholder">MDX inserter sequence — Phase 4</p>
      </div>
    </section>

    <section id="images" class="section">
      <div class="container">
        <h2>Working with images</h2>
        <p class="placeholder">Drag, rename, link, hover preview — Phase 4</p>
      </div>
    </section>

    <section id="features" class="section">
      <div class="container">
        <h2>And more</h2>
        <p class="placeholder">
          Drafts, copyedit modes, command palette — Phase 4
        </p>
      </div>
    </section>

    <section id="video" class="section">
      <div class="container">
        <h2>See it in action</h2>
        <p class="placeholder">YouTube facade — Phase 5</p>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  /* Shared layout tokens for the homepage. Palette comes from Layout.astro's
     Flexoki variables (which already swap on prefers-color-scheme). */
  :root {
    --home-container: 1100px;
    --home-pad-x: 1.5rem;
    --home-section-y: 6rem;
  }

  .container {
    width: 100%;
    max-width: var(--home-container);
    margin-inline: auto;
    padding-inline: var(--home-pad-x);
  }

  .section {
    padding-block: var(--home-section-y);
    border-top: 1px solid var(--color-border);
  }

  .section--hero {
    border-top: none;
  }

  /* ---- Hero ---- */
  .hero {
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero h1 {
    margin-top: 1rem;
    margin-inline: auto;
    max-width: 16ch;
  }

  .hero-sub {
    margin: 1.25rem auto 0;
    max-width: 42rem;
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .hero-cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .docs-link {
    color: var(--color-text);
    font-weight: 500;
    padding: 0.5rem 0.25rem;

    &:hover {
      color: var(--color-accent);
      text-decoration: none;
    }
  }

  .hero-visual {
    margin-top: 3.5rem;
  }

  /* Screenshots are captured on macOS and already carry their own window
     shadow, so they're rendered bare — no frame, border, or background. */
  .shot {
    display: block;
    margin-inline: auto;

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
    }
  }

  .shot--app {
    max-width: 1040px;
  }

  .shot--vscode {
    max-width: 820px;
  }

  .contrast-text {
    margin: 2.75rem auto;
    max-width: 34rem;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    line-height: 1.4;
    font-weight: 500;
    color: var(--color-text);
  }

  .focus-demo {
    margin-top: 4rem;
    max-width: 42rem;
    margin-inline: auto;
    text-align: left;
  }

  .focus-demo-lead {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .download-section {
    text-align: center;
  }

  .lede {
    margin-top: 0.75rem;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
  }

  .downloads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .primary-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .linux {
    width: 100%;
    max-width: 36rem;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .linux-alt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    a {
      color: var(--color-text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;

      &:hover {
        color: var(--color-text);
      }
    }
  }

  .brew {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    code {
      margin-left: 0.35rem;
      padding: 0.15rem 0.4rem;
      border-radius: 0.3rem;
      background: var(--color-bg-2);
      border: 1px solid var(--color-border);
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--color-text);
    }
  }

  @media (max-width: 600px) {
    .primary-row {
      width: 100%;
    }
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Temporary scaffold marker — removed as each section is built out. */
  .placeholder {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Tablet */
  @media (max-width: 900px) {
    :root {
      --home-section-y: 4rem;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    :root {
      --home-pad-x: 1.25rem;
      --home-section-y: 3rem;
    }
  }
</style>
