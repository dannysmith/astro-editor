---
import Layout from '@layouts/Layout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import DownloadButton from '../components/DownloadButton.astro'
import HeroDownload from '../components/HeroDownload.astro'
import FeatureSection from '../components/FeatureSection.astro'
import Screenshot from '../components/Screenshot.astro'
import ThemeCompareSlider from '../components/ThemeCompareSlider.astro'
import YouTubeFacade from '../components/YouTubeFacade.astro'
import Lightbox from '../components/Lightbox.astro'
import vscodeShot from '../assets/main-demo-image-vscode.png'
import aeLight from '../assets/main-demo-image-light.png'
import aeDark from '../assets/main-demo-image-dark.png'
import aeFocusLight from '../assets/main-demo-image-distractionless-light.png'
import aeFocusDark from '../assets/main-demo-image-distractionless-dark.png'
import frontmatterShot from '../assets/frontmatter-sidebar-overview.png'
import mdxShot from '../assets/mdx-builder-1.png'
import imagePreviewShot from '../assets/image-preview-demo.png'
import copyeditShot from '../assets/copyedit-highlights.png'
import commandPaletteShot from '../assets/command-palette.png'
import draftsShot from '../assets/file-manager-drafts-filter.png'

const RELEASE_BASE =
  'https://github.com/dannysmith/astro-editor/releases/latest/download'
const debUrl = `${RELEASE_BASE}/astro-editor-latest.deb`
const rpmUrl = `${RELEASE_BASE}/astro-editor-latest.rpm`

// The Astro Editor shot spans the hero (~1040px, 2x ≈ 2080); VS Code is smaller.
const heroImageWidths = [640, 1024, 1536, 2048]

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Astro Editor',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: ['macOS', 'Windows', 'Linux'],
  description:
    'A focused, schema-aware markdown editor for Astro content collections.',
  url: 'https://astroeditor.danny.is/',
  author: {
    '@type': 'Person',
    name: 'Danny Smith',
    url: 'https://danny.is',
  },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  downloadUrl: 'https://astroeditor.danny.is/',
}
---

<Layout
  title="Astro Editor — A focused markdown editor for Astro content collections"
  description="Astro Editor is a native, distraction-free markdown editor that reads your Astro content collection schemas and turns frontmatter into clean, schema-aware forms. For writer mode, not coder mode."
>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  <SiteHeader />

  <main>
    <section id="hero" class="section section--hero">
      <div class="container hero">
        <p class="eyebrow">For Astro content collections</p>
        <h1>Writer mode for your Astro content.</h1>
        <p class="hero-sub">
          A beautiful distraction-free markdown editor for working with Astro
          content collections, designed specifically for <strong>writing</strong
          > not coding. It uses your Astro config and Zod schemas to show frontmatter
          as proper forms, makes adding images & components easy and <strong
            >gets out of the way when you wanna just write</strong
          >.
        </p>

        <HeroDownload />

        <div class="shot shot--app">
          <Screenshot
            bare
            src={aeLight}
            darkSrc={aeDark}
            alt="The same file open in Astro Editor: a file list on the left, a schema-aware frontmatter form with a cover image on the right, and clean prose in the middle."
            loading="eager"
            widths={heroImageWidths}
            sizes="(max-width: 1099px) 92vw, 1040px"
          />
        </div>

        <p class="hero-step">
          Astro Editor works with local markdown & MDX files in Astro <a
            href="https://docs.astro.build/en/guides/content-collections/"
            >Content Collections</a
          >. It reads your <code>content.config.ts</code> to understand your collections
          and schemas and only shows you the stuff relevant to actually working with
          your content files.
        </p>
        <p class="hero-step">
          When you want to focus on writing to the exclusion of all else, you
          can hide the sidebars and use the <a
            href="/editor/focus-and-typewriter">Focus & Typewriter</a
          > features to write in a distraction-free environment...
        </p>

        <div class="shot shot--app">
          <Screenshot
            bare
            src={aeFocusLight}
            darkSrc={aeFocusDark}
            alt="Astro Editor in distraction-free mode: both sidebars and the toolbar hidden, with focus mode dimming everything but the current line."
            loading="lazy"
            widths={heroImageWidths}
            sizes="(max-width: 1099px) 92vw, 1040px"
          />
        </div>

        <div class="vscode-box">
          <h2 class="vscode-heading">Why not just use VS Code?</h2>
          <p>
            The two screenshots above show an entry in a <code>books</code>
            collection. Here's the same file open in VS Code. Astro Editor exists
            because this is an awful environment for writing prose in. See
            <a href="/getting-started/philosophy/">the philosophy page</a> for more
            on this.
          </p>

          <div class="shot shot--vscode">
            <Screenshot
              bare
              src={vscodeShot}
              alt="The same content file open in VS Code — a wall of raw YAML frontmatter above the prose, surrounded by editor chrome."
              loading="lazy"
              widths={heroImageWidths}
              sizes="(max-width: 980px) 92vw, 880px"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section features-header">
      <div class="container">
        <h2 class="features-title">Features</h2>
      </div>
    </section>

    <FeatureSection
      id="frontmatter"
      eyebrow="Frontmatter"
      title="Forms built from your schemas"
      flush
    >
      <p>
        Astro Editor reads your collection's schemas and renders the right
        control for every field — text inputs, date pickers, enum dropdowns, tag
        arrays, boolean switches, nested objects and the like. Image fields
        include previews and <code>reference()</code> fields render as dropdowns of
        the referenced collection.
      </p>
      <p>
        Every field in the schema shows up even if it's not yet in the file's
        frontmatter. So no more digging through <code>content.config.ts</code> to
        remember what's required, what's optional, or what an enum's allowed values
        are.
      </p>
      <Screenshot
        slot="media"
        src={frontmatterShot}
        alt="Astro Editor with the markdown editor on the left and a frontmatter panel on the right showing Title, Source URL, Slug, Draft, Description, Pub Date, Tags and Category fields generated from the schema."
        caption="Fields generated from the collection schema, right beside the editor."
      />
    </FeatureSection>

    <FeatureSection
      id="writing"
      eyebrow="Designed for writing"
      title="A writing surface, not a code editor"
      reverse
    >
      <p>
        Designed to keep you in a state of flow when you're writing, Astro
        Editor is designed for <strong
          ><a href="/getting-started/philosophy/">writer mode</a></strong
        > and includes:
      </p>
      <ul class="feature-list">
        <li>
          Carefully-designed typography inspired by <a
            href="https://ia.net/writer">iA Writer</a
          >
        </li>
        <li>
          A focus mode that dims everything but the sentence you're currently
          writing
        </li>
        <li>Typewriter mode, which keeps your cursor vertically centered</li>
        <li>
          Tiny little quality-of-life things: paste URLs over selected text to
          insert a link
        </li>
        <li>Keyboard shortcuts for everything</li>
        <li>
          <kbd>⌥</kbd> hover any image path to preview, <kbd>⌘</kbd> click to open
          any URL
        </li>
      </ul>
      <ThemeCompareSlider
        slot="media"
        lightSrc={aeLight}
        darkSrc={aeDark}
        alt="The same Astro Editor window shown in light and dark themes."
      />
    </FeatureSection>

    <FeatureSection
      id="mdx"
      eyebrow="MDX components"
      title="Insert components without leaving the keyboard"
    >
      <p>
        If you use components like <code>&lt;Aside&gt;</code> in your MDX content
        files, Astro Editor makes it easier to find and insert them <em
          >as you're writing</em
        >. The <a href="/editor/mdx-components">Component Inserter</a> shows a subset
        of the components in your project and lets you insert them with a few keystrokes.
      </p>
      <Screenshot
        slot="media"
        src={mdxShot}
        alt="Astro Editor's component inserter open over an MDX file, listing components including InfoBox (Vue), Callout (Astro), Card (Vue), BookmarkCard (Astro) and Alert (React)."
        caption="Search and insert components from across your project's frameworks."
      />
    </FeatureSection>

    <FeatureSection
      id="images"
      eyebrow="Images"
      title="Drop in an image, get a clean link"
      reverse
    >
      <p>
        Dragging an image into the editor copies it into the right assets
        folder, gives it a web-safe name, and inserts the appropriate markdown
        code in your document. Naming conflicts and the like are handled for
        you, so you can drag as many screenshots and random images into your
        content as you like and they'll end up in the right place in your Astro
        site.
      </p>
      <p>
        The same smart image handling also powers schema image fields in the
        frontmatter panel.
      </p>
      <p>
        Holding ⌥ while hovering any image path pops up a preview in the corner,
        so it's a tiny bit easier to check your image paths are right.
      </p>
      <div slot="media" class="media-stack">
        <Screenshot
          src={imagePreviewShot}
          alt="An image path in the editor being hovered, with a thumbnail preview floating in the bottom-right corner of the window."
          caption="⌥-hover an image path or URL to preview it in the corner."
        />
      </div>
    </FeatureSection>

    <section id="features" class="section">
      <div class="container">
        <h2 class="section-heading">And plenty more besides...</h2>
        <div class="cards">
          <article class="card">
            <Screenshot
              src={draftsShot}
              alt="The file list sidebar filtered to drafts, with two files marked by red Draft badges, alongside filter and sort controls."
              sizes="(max-width: 860px) 92vw, 340px"
              widths={[340, 510, 680]}
            />
            <h3>Drafts, filtering &amp; sorting</h3>
            <p>
              Filter and sort your content collections. See and filter drafts
              with ease.
            </p>
          </article>
          <article class="card">
            <Screenshot
              src={copyeditShot}
              alt="Prose in the editor with words colour-coded by part of speech — nouns, verbs, adjectives, adverbs and conjunctions in different colours."
              sizes="(max-width: 860px) 92vw, 340px"
              widths={[340, 510, 680]}
            />
            <h3>Copyedit modes</h3>
            <p>
              Colour-code parts of speech like nouns, verbs, adjectives, adverbs
              and conjunctions to help with editing & rewriting.
            </p>
          </article>
          <article class="card">
            <Screenshot
              src={commandPaletteShot}
              alt="Astro Editor's command palette open over a document, listing File and Navigation commands like New File, Close File and Toggle Sidebar."
              sizes="(max-width: 860px) 92vw, 340px"
              widths={[340, 510, 680]}
            />
            <h3>Global command palette</h3>
            <p>
              The whole app is keyboard-navigable. Open the palette to jump
              anywhere or run any command.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section id="download" class="section">
      <div class="container download-section">
        <h2>Download Astro Editor</h2>
        <p class="lede">
          Native builds for macOS, Windows, and Linux. Free and open source.
        </p>

        <div class="downloads">
          <div class="primary-row">
            <DownloadButton platform="macos" />
            <DownloadButton platform="windows" />
          </div>

          <p class="brew">
            Or install via Homebrew:
            <code>brew install --cask astro-editor</code>
          </p>

          <div class="linux">
            <DownloadButton platform="linux" />
            <p class="linux-alt">
              Linux is in beta. Also available as a{' '}
              <a href={debUrl}>.deb</a> or <a href={rpmUrl}>.rpm</a> package.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="video" class="section">
      <div class="container video-section">
        <h2 class="section-heading">See it in action</h2>
        <div class="video-frame">
          <YouTubeFacade
            id="SJkXD59gQ5U"
            title="Astro Editor — a walkthrough"
          />
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />

  <Lightbox />
</Layout>

<style>
  /* Layout primitives (.container, .section, --home-* tokens) and the Flexoki
     palette live in Layout.astro's global styles. */
  .section--hero {
    border-top: none;
  }

  /* ---- Hero ---- */
  .hero {
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero h1 {
    margin-top: 1rem;
    margin-inline: auto;
    max-width: 16ch;
  }

  .hero-sub {
    margin: 1.25rem auto 0;
    max-width: 42rem;
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  /* Screenshots are captured on macOS and already carry their own window
     shadow, so they're rendered bare — no frame, border, or background. */
  .shot {
    display: block;
    margin-inline: auto;

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
    }
  }

  .shot--app {
    max-width: 1040px;
  }

  .shot--vscode {
    max-width: 820px;
  }

  /* Even vertical rhythm for the stacked hero shots. */
  .hero .shot--app {
    margin-top: 3rem;
  }

  /* The "…and when you want focus…" aside, styled like the intro paragraph. */
  .hero-step {
    margin: 3rem auto 0;
    max-width: 42rem;
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  /* A faintly red-tinted, left-aligned card that sets the VS Code "before"
     apart from the bare, centred app shots above it. */
  .vscode-box {
    --vscode-tint: light-dark(#af3029, #d14d41); /* Flexoki red */
    margin: 4rem auto 0;
    max-width: 940px;
    padding: 2rem;
    text-align: left;
    border-radius: 1rem;
    border: 1px solid
      color-mix(in srgb, var(--vscode-tint) 22%, var(--color-border));
    background: color-mix(in srgb, var(--vscode-tint) 7%, var(--color-bg));
  }

  .vscode-heading {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .vscode-box p {
    max-width: 46rem;
    margin: 0.75rem 0 1.5rem;
    font-size: 1.0625rem;
    color: var(--color-text-muted);
  }

  .vscode-box .shot--vscode {
    max-width: 100%;
  }

  /* ---- Feature sections ---- */
  /* Group heading above the run of feature sections. Its top border is the
     divider from the hero; the first feature is `flush` so no line sits
     between this heading and it. */
  .features-header {
    padding-bottom: 0;
    text-align: center;
  }

  .features-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
  }

  .feature-list {
    margin-top: 1.25rem;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .feature-list li {
    position: relative;
    padding-left: 1.4rem;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .media-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .video-frame {
    max-width: 820px;
    margin-inline: auto;
  }

  /* ---- "And more" cards ---- */
  .section-heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .card h3 {
    margin-top: 1.25rem;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .card p {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .cards {
      grid-template-columns: 1fr;
      max-width: 28rem;
      margin-inline: auto;
    }
  }

  .download-section {
    text-align: center;
  }

  .lede {
    margin-top: 0.75rem;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
  }

  .downloads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .primary-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .linux {
    width: 100%;
    max-width: 36rem;
    padding: 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .linux-alt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    a {
      color: var(--color-text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;

      &:hover {
        color: var(--color-text);
      }
    }
  }

  .brew {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;

    code {
      margin-left: 0.35rem;
      padding: 0.15rem 0.4rem;
      border-radius: 0.3rem;
      background: var(--color-bg-2);
      border: 1px solid var(--color-border);
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--color-text);
    }
  }

  @media (max-width: 600px) {
    .primary-row {
      width: 100%;
    }
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
</style>
