---
/**
 * DownloadButton — a single blue "Download for <platform>" CTA.
 *
 * Reusable across the homepage and the docs. For Linux it links the AppImage
 * (the other Linux formats are offered as plain links wherever this is used).
 *
 *   <DownloadButton platform="macos" />
 */
import { DOWNLOADS } from '../consts'

type Platform = 'macos' | 'windows' | 'linux'

interface Props {
  platform: Platform
}
const { platform } = Astro.props

const config: Record<
  Platform,
  { href: string; title: string; sub: string; label: string }
> = {
  macos: {
    href: DOWNLOADS.mac,
    title: 'Download for macOS',
    sub: 'Universal (Intel & Apple Silicon)',
    label:
      'Download Astro Editor for macOS (Universal — Intel & Apple Silicon)',
  },
  windows: {
    href: DOWNLOADS.windows,
    title: 'Download for Windows',
    sub: 'Windows Installer',
    label: 'Download Astro Editor for Windows',
  },
  linux: {
    href: DOWNLOADS.linuxAppImage,
    title: 'Download for Linux',
    sub: 'AppImage package',
    label: 'Download Astro Editor for Linux (AppImage)',
  },
}
const c = config[platform]
---

<a class="download-btn" href={c.href} aria-label={c.label}>
  {
    platform === 'macos' && (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701" />
      </svg>
    )
  }
  {
    platform === 'windows' && (
      <svg
        width="17"
        height="17"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801" />
      </svg>
    )
  }
  {
    platform === 'linux' && (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M16.5 9.4 7.55 4.24" />
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
        <polyline points="3.29 7 12 12 20.71 7" />
        <line x1="12" x2="12" y1="22" y2="12" />
      </svg>
    )
  }
  <span class="btn-text">
    <span class="btn-title">{c.title}</span>
    <span class="btn-sub">{c.sub}</span>
  </span>
</a>

<style>
  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0.625rem;
    font-weight: 500;
    line-height: 1.2;
    background: var(--color-accent);
    color: #fff;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;

    &:hover {
      background: var(--color-accent-hover);
      color: #fff;
      text-decoration: none;
    }

    svg {
      flex-shrink: 0;
    }
  }

  .btn-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .btn-title {
    font-size: 0.95rem;
  }

  .btn-sub {
    font-size: 0.75rem;
    opacity: 0.8;
    font-weight: 400;
  }

  @media (max-width: 600px) {
    .download-btn {
      width: 100%;
      justify-content: center;
    }

    .btn-text {
      align-items: center;
    }
  }
</style>
