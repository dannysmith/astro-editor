---
/**
 * Lightbox — one shared <dialog> for full-resolution image previews.
 *
 * Rendered once per page. Any element carrying `data-lightbox-src` (and
 * optional `data-lightbox-src-dark` / `data-lightbox-alt`) opens it on click.
 * The native modal <dialog> handles Escape, focus trapping, and the backdrop;
 * clicking the backdrop closes it too.
 */
---

<dialog class="lightbox" aria-label="Image preview">
  <img class="lightbox-img" alt="" />
  <button class="lightbox-close" type="button" aria-label="Close preview">
    <svg
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <line x1="6" y1="6" x2="18" y2="18"></line>
      <line x1="18" y1="6" x2="6" y2="18"></line>
    </svg>
  </button>
</dialog>

<style>
  /* Fill the viewport and flex-center the image, so it stays centred on
     screens of any size (UA auto-centring only holds when the dialog box is
     sized to its content). */
  .lightbox {
    width: 100vw;
    max-width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    overflow: hidden;
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox::backdrop {
    background: rgb(0 0 0 / 0.82);
    backdrop-filter: blur(2px);
  }

  .lightbox-img {
    display: block;
    max-width: 94vw;
    max-height: 94vh;
    width: auto;
    height: auto;
    border-radius: 0.5rem;
  }

  .lightbox-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: #fff;
    background: rgb(255 255 255 / 0.12);

    &:hover {
      background: rgb(255 255 255 / 0.22);
    }
  }
</style>

<script>
  const dialog = document.querySelector<HTMLDialogElement>('.lightbox')
  const img = dialog?.querySelector<HTMLImageElement>('.lightbox-img')
  const closeBtn = dialog?.querySelector<HTMLButtonElement>('.lightbox-close')

  if (dialog && img && closeBtn) {
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)')

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement
      const trigger = target.closest<HTMLElement>('[data-lightbox-src]')
      if (!trigger) return
      e.preventDefault()
      const dark = prefersDark.matches && trigger.dataset.lightboxSrcDark
      img.src = dark
        ? trigger.dataset.lightboxSrcDark!
        : trigger.dataset.lightboxSrc!
      img.alt = trigger.dataset.lightboxAlt ?? ''
      dialog.showModal()
    })

    closeBtn.addEventListener('click', () => dialog.close())

    // Click on the backdrop (the dialog element itself) closes.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close()
    })

    // Drop the heavy full-res src once closed.
    dialog.addEventListener('close', () => {
      img.removeAttribute('src')
    })
  }
</script>
