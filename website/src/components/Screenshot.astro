---
/**
 * Screenshot — a framed app screenshot for the homepage feature sections.
 *
 * Unlike the hero's bare macOS shots (which carry their own window shadow),
 * the feature screenshots are captured edge-to-edge, so they get a subtle
 * border + shadow frame here. Pass `darkSrc` to serve a dark-mode variant via
 * a <picture> source (the page follows prefers-color-scheme).
 */
import { Image, getImage } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt: string
  darkSrc?: ImageMetadata
  caption?: string
  sizes?: string
  widths?: number[]
  loading?: 'lazy' | 'eager'
}

const {
  src,
  alt,
  darkSrc,
  caption,
  sizes = '(max-width: 860px) 92vw, 520px',
  widths = [520, 780, 1040],
  loading = 'lazy',
} = Astro.props

const darkOptimised = darkSrc
  ? await getImage({ src: darkSrc, format: 'webp', widths })
  : null
---

<figure class="screenshot">
  <div class="screenshot-frame">
    {
      darkOptimised ? (
        <picture>
          <source
            srcset={darkOptimised.srcSet.attribute}
            sizes={sizes}
            media="(prefers-color-scheme: dark)"
            type="image/webp"
          />
          <Image
            src={src}
            alt={alt}
            widths={widths}
            sizes={sizes}
            loading={loading}
          />
        </picture>
      ) : (
        <Image
          src={src}
          alt={alt}
          widths={widths}
          sizes={sizes}
          loading={loading}
        />
      )
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .screenshot {
    margin: 0;
  }

  .screenshot-frame {
    border-radius: 0.6rem;
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: var(--color-bg-2);
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.12);

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
    }
  }

  figcaption {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
