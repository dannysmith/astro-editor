---
/**
 * Screenshot — a framed app screenshot for the homepage feature sections.
 *
 * Feature screenshots are captured edge-to-edge, so they get a subtle border +
 * shadow frame. Pass `bare` for shots that already carry their own window
 * shadow (the hero macOS shots) — they keep the click-to-zoom lightbox but
 * drop the frame. Pass `darkSrc` to serve a dark-mode variant via a <picture>
 * source (the page follows prefers-color-scheme).
 */
import { Image, getImage } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt: string
  darkSrc?: ImageMetadata
  caption?: string
  bare?: boolean
  sizes?: string
  widths?: number[]
  loading?: 'lazy' | 'eager'
}

const {
  src,
  alt,
  darkSrc,
  caption,
  bare = false,
  sizes = '(max-width: 860px) 92vw, 640px',
  widths = [640, 960, 1280],
  loading = 'lazy',
} = Astro.props

const darkOptimised = darkSrc
  ? await getImage({ src: darkSrc, format: 'webp', widths })
  : null

// Full-resolution webp for the lightbox (highest resolution we have).
const fullLight = await getImage({ src, format: 'webp' })
const fullDark = darkSrc
  ? await getImage({ src: darkSrc, format: 'webp' })
  : null
---

<figure class="screenshot">
  <button
    class:list={['screenshot-frame', 'screenshot-trigger', { bare }]}
    type="button"
    data-lightbox-src={fullLight.src}
    data-lightbox-src-dark={fullDark?.src}
    data-lightbox-alt={alt}
    aria-label={`Open full-size image: ${alt}`}
  >
    {
      darkOptimised ? (
        <picture>
          <source
            srcset={darkOptimised.srcSet.attribute}
            sizes={sizes}
            media="(prefers-color-scheme: dark)"
            type="image/webp"
          />
          <Image
            src={src}
            alt={alt}
            widths={widths}
            sizes={sizes}
            loading={loading}
          />
        </picture>
      ) : (
        <Image
          src={src}
          alt={alt}
          widths={widths}
          sizes={sizes}
          loading={loading}
        />
      )
    }
  </button>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .screenshot-frame {
    appearance: none;
    display: block;
    width: 100%;
    color: inherit;
    font: inherit;
    border-radius: 0.6rem;
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: var(--color-bg-2);
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.12);

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
    }
  }

  /* Bare shots already carry their own window shadow — drop the frame but keep
     the click-to-zoom affordance. */
  .screenshot-frame.bare {
    border: none;
    border-radius: 0;
    overflow: visible;
    background: none;
    box-shadow: none;
  }

  .screenshot-trigger {
    cursor: zoom-in;
    transition: box-shadow 0.15s ease;
  }

  .screenshot-trigger:hover {
    box-shadow: 0 14px 38px rgb(0 0 0 / 0.2);
  }

  .screenshot-frame.bare:hover {
    box-shadow: none;
  }

  .screenshot-trigger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .screenshot-trigger {
      transition: none;
    }
  }

  figcaption {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
