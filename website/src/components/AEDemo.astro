---
/**
 * AEDemo — a faux Astro Editor pane that types out markdown and styles it
 * exactly as the app does (dimmed syntax marks, iA Writer font, editor colours).
 *
 * Usage:
 *   <AEDemo inline code="This is **bold text** here" />
 *   <AEDemo code={`# Title\n\nSome **markdown**...`} />
 *
 * The server renders the final styled state (works without JS / for reduced
 * motion); the client script replaces it with the typing animation.
 */
import { renderMarkdown } from './aedemo/highlight'

interface Props {
  /** The markdown to type out. Use a template literal with `\n` for blocks. */
  code: string
  /** Render inline (flows in a sentence) rather than as an editor pane. */
  inline?: boolean
  /** Milliseconds per character (default 48). */
  speed?: number
}

const { code, inline = false, speed } = Astro.props
const ssr = renderMarkdown(code, { inline })
const Tag = inline ? 'span' : 'div'
---

<Tag
  class:list={['ae-demo', inline ? 'ae-demo-inline' : 'ae-demo-block']}
  data-aedemo={JSON.stringify(code)}
  data-inline={String(inline)}
  data-speed={speed}
  set:html={ssr}
/>

<style is:global>
  @font-face {
    font-family: 'iA Writer Duo Web';
    src: url('/fonts/iAWriterDuoV.ttf') format('truetype-variations');
    font-weight: 400 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'iA Writer Duo Web';
    src: url('/fonts/iAWriterDuoV-Italic.ttf') format('truetype-variations');
    font-weight: 400 700;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'iA Writer Mono Web';
    src: url('/fonts/iAWriterMonoV.ttf') format('truetype-variations');
    font-weight: 400 700;
    font-style: normal;
    font-display: swap;
  }

  .ae-demo {
    --ae-carat: rgba(0, 195, 255, 1);
    --ae-bg: rgba(247, 247, 247, 1);
    --ae-text: rgba(25, 25, 25, 1);
    --ae-mdtag: rgba(179, 181, 176, 1);
    --ae-codebg: rgba(238, 238, 238, 0.6);
    --ae-link: rgba(53, 118, 182, 1);
    --ae-underline: rgba(214, 212, 209, 1);
    --ae-heading: var(--ae-text);
    font-family:
      'iA Writer Duo Web', 'iA Writer Duo', -apple-system, 'Segoe UI', Roboto,
      sans-serif;
    font-weight: 490;
    color: var(--ae-text);
  }

  [data-theme='dark'] .ae-demo {
    --ae-bg: rgba(26, 26, 26, 1);
    --ae-text: rgba(204, 204, 204, 1);
    --ae-mdtag: rgba(122, 122, 120, 1);
    --ae-codebg: rgba(37, 37, 37, 0.6);
    --ae-link: rgba(124, 159, 192, 1);
    --ae-underline: rgba(84, 84, 82, 1);
    font-weight: 480;
  }

  .ae-demo-block {
    display: block;
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: var(--ae-bg);
    border: 1px solid color-mix(in srgb, var(--ae-text) 12%, transparent);
    border-radius: 0.6rem;
    font-size: 0.95rem;
    line-height: 1.65;
    overflow-x: auto;
  }
  .ae-demo-block .ae-line {
    white-space: pre-wrap;
    min-height: 1.65em;
  }

  .ae-demo-inline {
    white-space: pre-wrap;
    font-size: 0.95em;
  }

  .ae-demo .ae-mark {
    color: var(--ae-mdtag);
  }
  .ae-demo .ae-strong {
    font-weight: 700;
  }
  .ae-demo .ae-em {
    font-style: italic;
  }
  .ae-demo .ae-code {
    font-family: 'iA Writer Mono Web', ui-monospace, monospace;
    background: var(--ae-codebg);
    padding: 0.05em 0.3em;
    border-radius: 3px;
  }
  .ae-demo .ae-link {
    color: var(--ae-link);
    text-decoration: underline;
    text-decoration-color: var(--ae-underline);
  }
  .ae-demo .ae-heading {
    font-weight: 700;
    color: var(--ae-heading);
  }
  .ae-demo .ae-h1 {
    font-size: 1.5em;
  }
  .ae-demo .ae-h2 {
    font-size: 1.3em;
  }
  .ae-demo .ae-h3 {
    font-size: 1.15em;
  }
  .ae-demo .ae-quote {
    color: var(--ae-mdtag);
    font-style: italic;
  }
  .ae-demo .ae-codeline {
    font-family: 'iA Writer Mono Web', ui-monospace, monospace;
    background: var(--ae-codebg);
  }
  .ae-demo .ae-hr {
    color: var(--ae-mdtag);
  }

  .ae-demo .ae-caret {
    display: inline-block;
    width: 2px;
    height: 1.1em;
    margin-left: 1px;
    vertical-align: text-bottom;
    background: var(--ae-carat);
    animation: ae-caret-blink 1s steps(1) infinite;
  }
  @keyframes ae-caret-blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ae-demo .ae-caret {
      display: none;
    }
  }
</style>

<script>
  import './aedemo/animate'
</script>
