---
/**
 * AEDemo — a faux Astro Editor pane that types out markdown and styles it
 * exactly as the app does (dimmed syntax marks, iA Writer font, editor colours).
 *
 * Usage:
 *   <AEDemo inline code="This is **bold text** here" />
 *   <AEDemo code={`# Title\n\nSome **markdown**...`} />
 *
 * Block demos reserve their final height (a hidden "sizer" copy) so the page
 * doesn't reflow as the animation loops. The server renders the final styled
 * state (works without JS / for reduced motion); the client script overlays
 * the typing animation and only plays while the demo is in view.
 */
import { renderMarkdown } from './aedemo/highlight'

interface Props {
  /** The markdown to type out. Use a template literal with `\n` for blocks. */
  code: string
  /** Render inline (flows in a sentence) rather than as an editor pane. */
  inline?: boolean
  /** Milliseconds per character (default 48). */
  speed?: number
  /**
   * Animation behaviour (default `loop`):
   * - `loop` — type out, hold, and repeat
   * - `once` — type out a single time, then stop
   * - `none` — show the finished state with no animation
   */
  animate?: 'loop' | 'once' | 'none'
}

const { code, inline = false, speed, animate = 'loop' } = Astro.props
const ssr = renderMarkdown(code, { inline })
---

{
  inline ? (
    <span
      class="ae-demo ae-demo-inline"
      data-aedemo={JSON.stringify(code)}
      data-inline="true"
      data-speed={speed}
      data-animate={animate}
      set:html={ssr}
    />
  ) : (
    <div
      class="ae-demo ae-demo-block"
      data-aedemo={JSON.stringify(code)}
      data-inline="false"
      data-speed={speed}
      data-animate={animate}
    >
      <div class="ae-sizer" aria-hidden="true" set:html={ssr} />
      <div class="ae-anim" set:html={ssr} />
    </div>
  )
}

<style is:global>
  @font-face {
    font-family: 'iA Writer Duo Web';
    src: url('/fonts/iAWriterDuoV.ttf') format('truetype-variations');
    font-weight: 400 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'iA Writer Duo Web';
    src: url('/fonts/iAWriterDuoV-Italic.ttf') format('truetype-variations');
    font-weight: 400 700;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'iA Writer Mono Web';
    src: url('/fonts/iAWriterMonoV.ttf') format('truetype-variations');
    font-weight: 400 700;
    font-style: normal;
    font-display: swap;
  }

  .ae-demo {
    --ae-caret: rgba(0, 195, 255, 1);
    --ae-bg: rgba(247, 247, 247, 1);
    --ae-text: rgba(25, 25, 25, 1);
    --ae-mdtag: rgba(179, 181, 176, 1);
    --ae-codebg: rgba(238, 238, 238, 0.5);
    --ae-underline: rgba(214, 212, 209, 1);
    --ae-heading: var(--ae-text);
    --ae-mono: 'iA Writer Mono Web', ui-monospace, monospace;
    font-family:
      'iA Writer Duo Web',
      'iA Writer Duo',
      -apple-system,
      'Segoe UI',
      Roboto,
      sans-serif;
    font-weight: 490;
    color: var(--ae-text);

    [data-theme='dark'] & {
      --ae-bg: rgba(26, 26, 26, 1);
      --ae-text: rgba(204, 204, 204, 1);
      --ae-mdtag: rgba(122, 122, 120, 1);
      --ae-codebg: rgba(37, 37, 37, 0.5);
      --ae-underline: rgba(84, 84, 82, 1);
      font-weight: 480;
    }

    .ae-mark {
      color: var(--ae-mdtag);
    }
    .ae-strong {
      font-weight: 700;
    }
    .ae-em {
      font-style: italic;
    }
    .ae-code {
      font-family: var(--ae-mono);
      background: var(--ae-codebg);
      padding: 0.05em 0.3em;
      border-radius: 3px;
    }
    .ae-link {
      color: var(--ae-mdtag);
      text-decoration: underline;
      text-decoration-color: var(--ae-underline);
    }
    .ae-heading {
      font-weight: 700;
      color: var(--ae-heading);
    }
    /* The app does not scale headings — they share the body size and are
       only bold. The hash marks take the heading colour (not the dimmed
       mdtag used for other syntax marks). */
    .ae-heading-mark {
      color: var(--ae-heading);
      font-weight: 700;
    }
    .ae-quote {
      color: var(--ae-mdtag);
      font-style: italic;
    }
    .ae-codeline {
      font-family: var(--ae-mono);
      background: var(--ae-codebg);
      margin-top: 0;
    }
    .ae-hr {
      color: var(--ae-mdtag);
    }

    /* To override styles from starlight */
    .ae-anim {
      margin-top: 0;
    }

    .ae-caret {
      display: inline-block;
      width: 2px;
      height: 1.3em;
      margin-left: 3px;
      vertical-align: text-bottom;
      background: var(--ae-caret);
      animation: ae-caret-blink 1s steps(1) infinite;
    }
  }

  .ae-demo-block {
    position: relative;
    box-sizing: border-box;
    margin: 1.5rem 0;
    padding: 0;
    overflow: hidden;
    background: var(--ae-bg);
    border: 1px solid color-mix(in srgb, var(--ae-text) 12%, transparent);
    border-radius: 0.6rem;
    font-size: 0.95rem;
    line-height: 1.65;

    /* The hidden sizer reserves the final height; the anim overlays it so the
       box never changes size as the animation types and loops. */
    .ae-sizer,
    .ae-anim {
      box-sizing: border-box;
      padding: 1rem 1.25rem;
    }
    .ae-sizer {
      visibility: hidden;
    }
    .ae-anim {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    .ae-line {
      white-space: pre-wrap;
      min-height: 1.65em;
    }
  }

  .ae-demo-inline {
    background: var(--ae-bg);
    border: 1px solid color-mix(in srgb, var(--ae-text) 3%, transparent);
    padding: 0.15em 0.3em;
    border-radius: 3px;
    white-space: pre-wrap;
    font-size: 0.95em;
  }

  @keyframes ae-caret-blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ae-demo .ae-caret {
      display: none;
    }
  }
</style>

<script>
  import './aedemo/animate'
</script>
