{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "description": "This is the title of the article"
    },
    "slug": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "A brief description of the article"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "cover": {
      "type": "string"
    },
    "coverAlt": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "platform": {
      "type": "string",
      "enum": [
        "medium",
        "external"
      ]
    },
    "author": {},
    "relatedArticles": {
      "maxItems": 3,
      "type": "array",
      "items": {}
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "draft",
    "pubDate"
  ],
  "additionalProperties": false
}