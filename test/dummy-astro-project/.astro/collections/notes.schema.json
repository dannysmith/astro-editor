{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "The title of the note"
    },
    "sourceURL": {
      "type": "string",
      "format": "uri"
    },
    "slug": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "published"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "keywords": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "scores": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "description": "Category for organizing notes"
        },
        "priority": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "description": "Priority level from 1-5"
        },
        "deadline": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "category"
      ]
    },
    "coverImage": {
      "type": "object",
      "properties": {
        "image": {
          "type": "string"
        },
        "alt": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}