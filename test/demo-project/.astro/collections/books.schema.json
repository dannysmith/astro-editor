{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Title of the book"
    },
    "author": {
      "type": "string",
      "description": "Book author name"
    },
    "isbn": {
      "description": "ISBN-13 number",
      "type": "string"
    },
    "cover": {
      "description": "Book cover image",
      "type": "string"
    },
    "publicationYear": {
      "type": "number",
      "minimum": 1800,
      "maximum": 2030
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Rating out of 5 stars"
    },
    "dateRead": {
      "description": "Date finished reading",
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "description": "Genres or themes",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draftBookReview": {
      "default": false,
      "type": "boolean"
    },
    "reviewer": {},
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "author",
    "rating",
    "draftBookReview"
  ],
  "additionalProperties": false
}